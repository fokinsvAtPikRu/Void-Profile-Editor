<Window x:Class="Void_Profile_Editor.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Void_Profile_Editor.Views"
        mc:Ignorable="d"
        Title="Редактирование контура продавливания" Height="600" Width="400">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>

        <Button
            Grid.Row="0" Grid.Column="0"
            Margin="10" Padding="10"
            Content="Выбрать" 
            FontSize="20"
            Command="{Binding SelectFamilyInstanceCommand}"/>

        <Button
            Grid.Row="1" Grid.Column="0"
            Margin="10" Padding="10"
            Content="Построить контур" 
            FontSize="20"
            Command="{Binding CreateContourCommand}"/>
        <Button
             Grid.Row="2" Grid.Column="0"
             Margin="10" Padding="10"
             Content="Построить секущие линии" 
             FontSize="20"
             Command="{Binding CreateCutingLinesCommand}"/>
        <Button
             Grid.Row="3" Grid.Column="0"
             Margin="10" Padding="10"
             Content="Удалить контур" 
             FontSize="20"
             Command="{Binding DeleteContourCommand}"/>
        <ScrollViewer 
            Grid.Row="0" 
            Grid.Column="1" 
            Grid.RowSpan="5"
            VerticalScrollBarVisibility="Auto"
            HorizontalScrollBarVisibility="Disabled"
            Margin="5">

            <StackPanel>
                <!-- Информация о выбранном элементе и длине -->
                <Border BorderBrush="Gray" BorderThickness="1" CornerRadius="3" Padding="5" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="Информация:" FontWeight="Bold"/>
                        <TextBlock Text="{Binding SelectedElementInfo}" Margin="5,0,0,0"/>
                        <TextBlock Text="{Binding LengthInfo}" Margin="5,0,0,0" Foreground="Blue"/>
                        <TextBlock Text="Количество узлов: " Margin="5,0,0,0">
                            <Run Text="{Binding NodeCount, Mode=OneWay}"/>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- Заголовок для ввода усилий -->
                <TextBlock 
                    Text="Введите усилия в узлах:" 
                    FontWeight="Bold" 
                    Margin="0,5,0,5"/>

                <!-- Динамическое создание полей для каждого узла -->
                <ItemsControl ItemsSource="{Binding Nodes}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border 
                                BorderBrush="LightGray" 
                                BorderThickness="1" 
                                CornerRadius="3" 
                                Padding="5" 
                                Margin="0,0,0,5"
                                Background="#FFF9F9F9">

                                <StackPanel>
                                    <!-- Заголовок узла -->
                                    <TextBlock 
                                        Text="{Binding NodeName}" 
                                        FontWeight="SemiBold" 
                                        Foreground="#FF2E75B6"
                                        Margin="0,0,0,5"/>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <!-- N -->
                                        <TextBlock 
                                            Grid.Row="0" Grid.Column="0" 
                                            Text="N (кН):" 
                                            VerticalAlignment="Center"
                                            Margin="5,3,5,3"/>
                                        <TextBox 
                                            Grid.Row="0" Grid.Column="1" 
                                            Text="{Binding N, UpdateSourceTrigger=PropertyChanged}" 
                                            Margin="5,3,5,3"
                                            Padding="3"
                                            VerticalAlignment="Center"
                                            MinWidth="100"/>

                                        <!-- Mx -->
                                        <TextBlock 
                                            Grid.Row="1" Grid.Column="0" 
                                            Text="Mx (кН·м):" 
                                            VerticalAlignment="Center"
                                            Margin="5,3,5,3"/>
                                        <TextBox 
                                            Grid.Row="1" Grid.Column="1" 
                                            Text="{Binding Mx, UpdateSourceTrigger=PropertyChanged}" 
                                            Margin="5,3,5,3"
                                            Padding="3"
                                            VerticalAlignment="Center"/>

                                        <!-- My -->
                                        <TextBlock 
                                            Grid.Row="2" Grid.Column="0" 
                                            Text="My (кН·м):" 
                                            VerticalAlignment="Center"
                                            Margin="5,3,5,3"/>
                                        <TextBox 
                                            Grid.Row="2" Grid.Column="1" 
                                            Text="{Binding My, UpdateSourceTrigger=PropertyChanged}" 
                                            Margin="5,3,5,3"
                                            Padding="3"
                                            VerticalAlignment="Center"/>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Кнопка для применения усилий -->
                <Button 
                    Content="Применить усилия" 
                    Command="{Binding ApplyForcesCommand}"
                    Margin="0,10,0,0"
                    Padding="5"
                    HorizontalAlignment="Center"
                    MinWidth="120"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
